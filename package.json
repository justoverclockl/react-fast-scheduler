{
  "name": "@marco.colia/react-fast-scheduler",
  "version": "3.0.0",
  "description": "A lightweight React scheduling library.",
  "keywords": [
    "react",
    "scheduler",
    "calendar",
    "library"
  ],
  "license": "MIT",
  "author": "Marco Colia",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justoverclockl/react-fast-scheduler.git"
  },
  "homepage": "https://github.com/justoverclockl/react-fast-scheduler#readme",
  "bugs": {
    "url": "https://github.com/justoverclockl/react-fast-scheduler/issues"
  },
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "tsup",
    "build:css": "tailwindcss -i ./src/global.css -o ./dist/styles.css --minify && node ./scripts/scope-styles.mjs",
    "dev:demo": "vite",
    "changeset": "changeset",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "format": "eslint . --fix",
    "format:check": "eslint .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "npm run build && changeset publish",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.25.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/cli": "^4.1.13",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.25.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "postcss-prefix-selector": "^2.1.1",
    "prettier": "^3.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  }
}
